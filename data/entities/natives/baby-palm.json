{
  "type": "native",
  "name": "Baby Palm",
  "icon": "assets/entities/natives/palm/baby-palm.png",
  "coins": 2,
  "health": 3,
  "tooltip": "Young palm growing strong!",
  "mutable": {
    "onDestroy": {
      "condition": "playerHasItem:sickle",
      "failMessage": "The young palm is too delicate — you need a sickle to harvest safely!",
      "drop": [
        {
          "entity": "seed",
          "count": 1,
          "chance": 1.0
        }
      ]
    },
    "onInteract": {
      "dialogTree": [
        {
          "message": "This young palm needs care...",
          "choices": [
            { "text": "Leave it growing", "next": 1 },
            { "text": "Harvest a seed (with sickle)", "next": 2 }
          ]
        },
        { "message": "Good choice — let it grow strong." },
        { "message": "You carefully take a seed..." }
      ]
    },
    "onTimer": {
      "every": "2h",
      "spawn": "baby-palm",
      "count": 1
    }
  }
}